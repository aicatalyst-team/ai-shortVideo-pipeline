# Backend base URL. Leave empty in local dev to use the Vite /api proxy.
VITE_BACKEND_BASE=http://localhost:8000

# Mock mode. true means fetchStoryboard uses fixtures instead of the backend.
VITE_USE_MOCK=false

# Java gateway base URL: SSE + frame upload.
VITE_GATEWAY_BASE=http://localhost:8080

# Python orchestrator base URL: regenerate POST + job polling fallback.
VITE_PYTHON_BASE=http://localhost:8000

# Dev JWT token. Production should use login/cookie auth.
# Generate locally:
# python -c "import jwt,time; print(jwt.encode({'sub':'dev','tenant_id':'dev','iat':int(time.time()),'exp':int(time.time())+86400}, 'dev-only-secret-please-override-in-production-32bytes-min', algorithm='HS256'))"
VITE_DEV_JWT=
