# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=please-change-to-a-strong-password-16chars-min
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_INTERNAL_ENDPOINT=http://minio:9000
MINIO_PUBLIC_BUCKET=ai-platform-public
MINIO_PRIVATE_BUCKET=ai-platform-private

# LLM providers
DEEPSEEK_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=

# Kling video provider
KLING_BASE_URL=https://api-beijing.klingai.com
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_VIDEO_MODEL=kling-v2-5-turbo

# Langfuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

# D41-B CLIP consistency warning (keyframe prompt-image scoring)
CLIP_CONSISTENCY_ENABLED=true
CLIP_CONSISTENCY_THRESHOLD=0.22

# D41-C AV sync rescue (attempt to save generated video after hard drift)
AV_RESCUE_ENABLED=true
AV_RESCUE_TEMPO_MAX=1.30
AV_RESCUE_PAD_MAX_SEC=5.0
AV_RESCUE_REWRITE_MAX_DRIFT_SEC=15.0

# Gateway JWT secret (ISSUE-1 修复后必填，缺失或弱值时 compose / gateway 启动失败)
# 生成强随机：
#   openssl rand -base64 32
# 禁止使用包含 dev-only / please-override / change-me / do-not-use 的字串。
GATEWAY_AUTH_JWT_SECRET=
